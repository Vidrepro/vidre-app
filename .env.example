# Kopieer dit bestand naar .env.local en vul de waarden in
# Zie docs/SETUP-ONEDRIVE.md voor hoe je deze waarden krijgt

# Microsoft 365 / OneDrive
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
ONEDRIVE_USER_ID=
ONEDRIVE_BASE_PATH=Klantorders

# Optioneel: stuur ook een kopie per e-mail naar dit adres
# NOTIFY_EMAIL=
